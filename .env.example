# Copy this file to .env and adjust for your environment.

# Database — Neon PostgreSQL (serverless Postgres)
# Get your connection string from https://neon.tech
DATABASE_URL=postgresql://user:password@ep-your-project-pooler.region.aws.neon.tech/dbname?sslmode=require

# Frontend API base URL (Vite reads VITE_* vars at build/dev start).
# Relative path resolves against the page origin:
#   - In dev, API calls hit the Vite dev server which returns fast 404s for
#     un-proxied routes (the vite.config.ts api-404-fallback middleware).
#     Proxied routes (/api/v1/track, /api/v1/consultations, /api/v1/privacy/consent)
#     forward to the Hono services-api on port 3031.
#   - When you deploy a real backend, set this to its full URL, e.g.
#     VITE_API_URL=https://api.exxonim.tz/api/v1
VITE_API_URL=/api/v1

# ─────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────
/dist/
/build
/out/

# ─────────────────────────────────────────────────────────────
# Environment & secrets
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
.env.local

# ─────────────────────────────────────────────────────────────
# Runtime database (SQLite) — keep schema, ignore the data file
# ─────────────────────────────────────────────────────────────
db/*.db
db/*.db-journal
prisma/*.db
prisma/*.db-journal

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log

# ─────────────────────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db
.idea/
.vscode/
*.swp

# ─────────────────────────────────────────────────────────────
# Vite / tooling caches
# ─────────────────────────────────────────────────────────────
.vite/
coverage/
tool-results/
.zscripts/dev.pid
*.pid
*.exit

# ─────────────────────────────────────────────────────────────
# Agent / workspace artifacts (never ship these)
# ─────────────────────────────────────────────────────────────
/skills/
/agent-ctx/
/screenshots/
/upload/
/download/
/examples/
.claude
.z-ai-config
local-*
prompt

# Compiled binaries should never be committed
mini-server

# Preview / debug screenshots created during development
preview-*.png
boot-loader-*.png
audit-*.png
final-loaded.png

# ─────────────────────────────────────────────────────────────
# Misc
